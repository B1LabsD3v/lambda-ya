{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": false,
    "baseUrl": ".",
    "paths": {
      "@core/*": ["src/core/*"],
      "@config/*": ["src/config/*"],
      "@types_/*": ["src/core/@types/*"],
      "@services/*": ["src/service/*"],
      "@infrastructure/*": ["src/repository/*"]
    }
  },
  "include": ["src/**/*", "index.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "__test__",
    "src/**/r_example.example/**",
    "src/**/s_example.example/**",
    "src/**/example.example*.ts"
  ]
}
